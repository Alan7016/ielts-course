            <div class="listening-notes">
                <h3>Continuing your studies <em>after graduation</em></h3>
                <h4>Writing your <em>dissertation</em></h4>
                
                <p><strong>Important considerations:</strong></p>
                <ul>
                    <li>Many students struggle to find a research <span class="gap">(1)</span>.</li>
                    <li>Writing a <span class="gap">(2)</span> <em>is easier</em> if you make the right choice.</li>
                </ul>

                <p style="margin-top: 20px;"><strong>You need to:</strong></p>
                <ul>
                    <li>Study the <span class="gap">(3)</span>.</li>
                    <li>Have a <em>wide</em> <span class="gap">(4)</span> of your <em>field of study</em>.</li>
                    <li><em>Establish</em> what is <span class="gap">(5)</span> in your field.</li>
                    <li>Have a clear idea of the <span class="gap">(6)</span> of your study.</li>
                    <li><em>Consider</em> whether there are any <span class="gap">(7)</span> in existing research.</li>
                    <li><em>Think about</em> your <span class="gap">(8)</span> carefully.</li>
                    <li>Ask about <span class="gap">(9)</span> from outside sources.</li>
                    <li>Ask your <span class="gap">(10)</span> to check your <em>results</em>.</li>
                </ul>
            </div>

            <div class="task-buttons">
                <button class="btn btn-success" onclick="showAnswers(6); document.getElementById('nextBtn6').disabled=false;">Check Answers</button>
                <button class="btn btn-primary" id="nextBtn6" onclick="nextTask('task6')" disabled style="opacity: 0.5;">Complete</button>
            </div>

            <div class="answer-section" id="answers6">
                <div class="answer-title">✅ ANSWERS</div>
                <ol>
                    <li><strong>topic / question</strong></li>
                    <li><strong>dissertation</strong></li>
                    <li><strong>literature</strong></li>
                    <li><strong>knowledge / understanding</strong></li>
                    <li><strong>already known</strong></li>
                    <li><strong>scope / objectives</strong></li>
                    <li><strong>gaps</strong></li>
                    <li><strong>methodology</strong></li>
                    <li><strong>funding / support</strong></li>
                    <li><strong>supervisor</strong></li>
                </ol>
                <p style="margin-top: 15px; color: #666;"><em>Note: Answers may vary slightly. The key is staying within the 2-word limit and capturing the correct meaning from the audio.</em></p>
            </div>
        </div>

        <!-- Completion Screen -->
        <div class="task-card" id="completion">
            <div class="completion">
                <div class="completion-emoji">🎉</div>
                <div class="completion-title">Congratulations!</div>
                <div class="completion-text">You've successfully completed all tasks for Week 1, Day 1.<br>Great job on your learning journey!</div>
            </div>
        </div>

    </div>

    <script>
        let currentTask = 0;
        const totalTasks = 10; // Including break as a "task"
        const taskOrder = ['task1', 'task2', 'task3', 'break', 'task4', 'task5', 'task6'];

        function startLearning() {
            document.getElementById('splashScreen').classList.add('hidden');
            setTimeout(() => {
                document.getElementById('mainContainer').classList.add('active');
            }, 500);
        }

        function toggleVocab() {
            const content = document.getElementById('vocabContent');
            const arrow = document.getElementById('vocabArrow');
            content.classList.toggle('active');
            arrow.textContent = content.classList.contains('active') ? '▲' : '▼';
        }

        function showAnswers(taskNum) {
            document.getElementById('answers' + taskNum).classList.add('show');
        }

        // Task 1: Check answers with individual feedback
        function checkTask1Answers() {
            const answers = {
                'q1_1': ['overcome'],
                'q1_2': ['study'],
                'q1_3': ['concentrate'],
                'q1_4': ['find'],
                'q1_5': ['taking', 'doing'],
                'q1_6': ['learn'],
                'q1_7': ['doing'],
                'q1_8': ['revise', 'prepare'],
                'q1_9': ['revise'],
                'q1_10': ['taught']
            };

            for (let qId in answers) {
                const input = document.getElementById(qId);
                const feedback = document.getElementById('fb' + qId.substring(2)); // fb1_1, fb1_2, etc.
                const userAnswer = input.value.trim().toLowerCase();
                
                const correctAnswers = answers[qId];
                const isCorrect = correctAnswers.some(ans => ans.toLowerCase() === userAnswer);
                
                if (isCorrect) {
                    input.classList.remove('incorrect');
                    input.classList.add('correct');
                    feedback.textContent = '✅ Correct';
                    feedback.className = 'answer-feedback correct';
                } else {
                    input.classList.remove('correct');
                    input.classList.add('incorrect');
                    feedback.textContent = '❌ Incorrect (Answer: ' + correctAnswers.join(' or ') + ')';
                    feedback.className = 'answer-feedback incorrect';
                }
            }
        }

        function completeTask(taskNum) {
            // Show answers first
            if (document.getElementById('answers' + taskNum)) {
                document.getElementById('answers' + taskNum).classList.add('show');
            }
            
            // Wait a moment for answers to appear, then move to next task
            setTimeout(() => {
                nextTask(taskOrder[currentTask]);
            }, 800);
        }

        function nextTask(currentTaskId) {
            // Hide current task
            const current = document.getElementById(currentTaskId);
            current.classList.remove('active');

            // Move to next task
            currentTask++;
            
            if (currentTask < taskOrder.length) {
                const nextTaskId = taskOrder[currentTask];
                document.getElementById(nextTaskId).classList.add('active');
                
                // Update progress (excluding break from count)
                let progressCount = currentTask;
                if (currentTask >= 4) progressCount--; // Subtract 1 if we've passed the break
                
                const percentage = (progressCount / 9) * 100; // 9 actual tasks
                document.getElementById('progressBar').style.width = percentage + '%';
                document.getElementById('progressText').textContent = progressCount + ' / 9 Tasks';
                
                // Scroll to top
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
                // Show completion
                document.getElementById('completion').classList.add('active');
                document.getElementById('progressBar').style.width = '100%';
                document.getElementById('progressText').textContent = '9 / 9 Tasks - Complete!';
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }
    </script>
</body>
</html>
